# Application
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://masjidhub:masjidhub@localhost:5432/masjidhub?schema=public

# Auth
# Must be at least 32 characters. Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret-of-at-least-32-chars
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# CORS — comma-separated list of allowed origins (empty = same-origin only)
CORS_ORIGINS=

# Rate limiting (global defaults)
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=100

# Swagger UI at /api/docs (disable in production unless needed)
SWAGGER_ENABLED=true

# Password reset emails
# Frontend base URL used in reset links (…/reset-password?token=…)
APP_BASE_URL=http://localhost:3000
# SMTP connection URL, e.g. smtps://user:pass@smtp.example.com:465
# Leave unset in development to log emails instead of sending them.
SMTP_URL=
MAIL_FROM="MasjidHub <no-reply@masjidhub.local>"
PASSWORD_RESET_TTL_MINUTES=60

# Bootstrap platform admin (used by `npm run db:seed`)
PLATFORM_ADMIN_EMAIL=admin@masjidhub.local
PLATFORM_ADMIN_PASSWORD=change-me-strong-password
PLATFORM_ADMIN_FIRST_NAME=Platform
PLATFORM_ADMIN_LAST_NAME=Admin
