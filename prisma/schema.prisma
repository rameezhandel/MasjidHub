generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLATFORM_ADMIN
  MASJID_ADMIN
  MASJID_MAINTAINER
}

enum MasjidStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

/// Fajr/Isha angle conventions; maps to the adhan library's named methods.
enum CalculationMethod {
  MUSLIM_WORLD_LEAGUE
  ISNA
  EGYPTIAN
  UMM_AL_QURA
  KARACHI
  DUBAI
  KUWAIT
  QATAR
  SINGAPORE
  TURKEY
  MOON_SIGHTING_COMMITTEE
}

/// Juristic method for Asr: STANDARD (Shafi'i/Maliki/Hanbali) or HANAFI.
enum AsrMethod {
  STANDARD
  HANAFI
}

model Masjid {
  id           String       @id @default(uuid()) @db.Uuid
  name         String
  slug         String       @unique
  email        String?
  phone        String?
  website      String?
  addressLine1 String?      @map("address_line1")
  addressLine2 String?      @map("address_line2")
  city         String?
  state        String?
  postalCode   String?      @map("postal_code")
  country      String?
  timezone     String       @default("UTC")
  latitude     Float?
  longitude    Float?
  calculationMethod CalculationMethod @default(MUSLIM_WORLD_LEAGUE) @map("calculation_method")
  asrMethod    AsrMethod    @default(STANDARD) @map("asr_method")
  status       MasjidStatus @default(ACTIVE)
  users        User[]
  prayerTimes  PrayerTimetableEntry[]
  announcements Announcement[]
  events       Event[]
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@index([status])
  @@map("masjids")
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  email         String         @unique
  passwordHash  String         @map("password_hash")
  firstName     String         @map("first_name")
  lastName      String         @map("last_name")
  role          UserRole
  isActive      Boolean        @default(true) @map("is_active")
  masjid        Masjid?        @relation(fields: [masjidId], references: [id], onDelete: Restrict)
  masjidId      String?        @map("masjid_id") @db.Uuid
  refreshTokens RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  announcements Announcement[]
  events        Event[]
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@index([masjidId])
  @@map("users")
}

model PrayerTimetableEntry {
  id            String   @id @default(uuid()) @db.Uuid
  masjid        Masjid   @relation(fields: [masjidId], references: [id], onDelete: Cascade)
  masjidId      String   @map("masjid_id") @db.Uuid
  /// Calendar date in the masjid's local timezone.
  date          DateTime @db.Date
  /// All times are local wall-clock "HH:MM" strings in the masjid's timezone.
  fajr          String
  fajrIqamah    String?  @map("fajr_iqamah")
  dhuhr         String
  dhuhrIqamah   String?  @map("dhuhr_iqamah")
  asr           String
  asrIqamah     String?  @map("asr_iqamah")
  maghrib       String
  maghribIqamah String?  @map("maghrib_iqamah")
  isha          String
  ishaIqamah    String?  @map("isha_iqamah")
  jumuah1       String?
  jumuah2       String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([masjidId, date])
  @@map("prayer_timetable_entries")
}

model Announcement {
  id          String        @id @default(uuid()) @db.Uuid
  masjid      Masjid        @relation(fields: [masjidId], references: [id], onDelete: Cascade)
  masjidId    String        @map("masjid_id") @db.Uuid
  title       String
  body        String
  status      ContentStatus @default(DRAFT)
  publishedAt DateTime?     @map("published_at")
  createdBy   User?         @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdById String?       @map("created_by_id") @db.Uuid
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([masjidId, status])
  @@map("announcements")
}

model Event {
  id          String      @id @default(uuid()) @db.Uuid
  masjid      Masjid      @relation(fields: [masjidId], references: [id], onDelete: Cascade)
  masjidId    String      @map("masjid_id") @db.Uuid
  title       String
  description String?
  location    String?
  startsAt    DateTime    @map("starts_at")
  endsAt      DateTime?   @map("ends_at")
  status      EventStatus @default(DRAFT)
  createdBy   User?       @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdById String?     @map("created_by_id") @db.Uuid
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@index([masjidId, startsAt])
  @@index([masjidId, status])
  @@map("events")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  tokenHash String    @unique @map("token_hash")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String    @map("user_id") @db.Uuid
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  tokenHash String    @unique @map("token_hash")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String    @map("user_id") @db.Uuid
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}
