generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLATFORM_ADMIN
  MASJID_ADMIN
  MASJID_MAINTAINER
}

enum MasjidStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

/// Fajr/Isha angle conventions; maps to the adhan library's named methods.
enum CalculationMethod {
  MUSLIM_WORLD_LEAGUE
  ISNA
  EGYPTIAN
  UMM_AL_QURA
  KARACHI
  DUBAI
  KUWAIT
  QATAR
  SINGAPORE
  TURKEY
  MOON_SIGHTING_COMMITTEE
}

/// Juristic method for Asr: STANDARD (Shafi'i/Maliki/Hanbali) or HANAFI.
enum AsrMethod {
  STANDARD
  HANAFI
}

/// Lifecycle of a household registered under a masjid.
enum HouseholdStatus {
  ACTIVE
  INACTIVE
  MOVED_OUT
}

/// How often a household's membership fee recurs.
enum FeeFrequency {
  MONTHLY
  YEARLY
}

enum Gender {
  MALE
  FEMALE
}

/// Structured link between two household members for the family tree.
enum RelationshipType {
  /// Directed: fromMember is a parent of toMember.
  PARENT
  /// Undirected: the two members are spouses (stored once, ids sorted).
  SPOUSE
}

model Masjid {
  id           String       @id @default(uuid()) @db.Uuid
  name         String
  slug         String       @unique
  email        String?
  phone        String?
  website      String?
  addressLine1 String?      @map("address_line1")
  addressLine2 String?      @map("address_line2")
  city         String?
  state        String?
  postalCode   String?      @map("postal_code")
  country      String?
  timezone     String       @default("UTC")
  latitude     Float?
  longitude    Float?
  calculationMethod CalculationMethod @default(MUSLIM_WORLD_LEAGUE) @map("calculation_method")
  asrMethod    AsrMethod    @default(STANDARD) @map("asr_method")
  status       MasjidStatus @default(ACTIVE)
  users        User[]
  invitations  Invitation[]
  prayerTimes  PrayerTimetableEntry[]
  announcements Announcement[]
  events       Event[]
  households   Household[]
  memberRelationships MemberRelationship[]
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@index([status])
  @@map("masjids")
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  email         String         @unique
  passwordHash  String         @map("password_hash")
  firstName     String         @map("first_name")
  lastName      String         @map("last_name")
  role          UserRole
  isActive      Boolean        @default(true) @map("is_active")
  masjid        Masjid?        @relation(fields: [masjidId], references: [id], onDelete: Restrict)
  masjidId      String?        @map("masjid_id") @db.Uuid
  refreshTokens RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  invitationsSent Invitation[] @relation("InvitationsSent")
  auditLogs     AuditLog[]     @relation("AuditActor")
  announcements Announcement[]
  events        Event[]
  households    Household[]
  payments      HouseholdPayment[] @relation("PaymentRecordedBy")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@index([masjidId])
  @@map("users")
}

model Household {
  id           String            @id @default(uuid()) @db.Uuid
  masjid       Masjid            @relation(fields: [masjidId], references: [id], onDelete: Cascade)
  masjidId     String            @map("masjid_id") @db.Uuid
  /// Display label for the household, e.g. "Handel Family".
  familyName   String            @map("family_name")
  headName     String            @map("head_name")
  phone        String?
  email        String?
  addressLine1 String?           @map("address_line1")
  addressLine2 String?           @map("address_line2")
  city         String?
  state        String?
  postalCode   String?           @map("postal_code")
  country      String?
  notes        String?
  status       HouseholdStatus   @default(ACTIVE)
  /// Membership fee the admin sets for this household, in minor units (cents).
  feeAmountCents Int?            @map("fee_amount_cents")
  feeFrequency FeeFrequency?     @map("fee_frequency")
  /// Date from which the fee starts accruing (used to compute what's owed).
  feeStartOn   DateTime?         @map("fee_start_on") @db.Date
  members      HouseholdMember[]
  payments     HouseholdPayment[]
  createdBy    User?             @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdById  String?           @map("created_by_id") @db.Uuid
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  @@index([masjidId, status])
  @@index([masjidId, familyName])
  @@map("households")
}

/// An offline fee payment recorded against a household (cash, cheque, transfer).
model HouseholdPayment {
  id          String    @id @default(uuid()) @db.Uuid
  household   Household  @relation(fields: [householdId], references: [id], onDelete: Cascade)
  householdId String     @map("household_id") @db.Uuid
  amountCents Int        @map("amount_cents")
  paidOn      DateTime   @map("paid_on") @db.Date
  /// Free-text payment method, e.g. "Cash", "Bank transfer".
  method      String?
  /// What period the payment covers, e.g. "Jan 2026" or "2026".
  periodLabel String?    @map("period_label")
  note        String?
  recordedBy  User?      @relation("PaymentRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)
  recordedById String?   @map("recorded_by_id") @db.Uuid
  createdAt   DateTime   @default(now()) @map("created_at")

  @@index([householdId, paidOn])
  @@map("household_payments")
}

model HouseholdMember {
  id           String    @id @default(uuid()) @db.Uuid
  household    Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  householdId  String    @map("household_id") @db.Uuid
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  /// Free-text relationship to the head, e.g. "Spouse", "Son", "Daughter".
  relationship String?
  gender       Gender?
  dateOfBirth  DateTime? @map("date_of_birth") @db.Date
  phone        String?
  email        String?
  relationshipsFrom MemberRelationship[] @relation("RelFrom")
  relationshipsTo   MemberRelationship[] @relation("RelTo")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([householdId])
  @@map("household_members")
}

model MemberRelationship {
  id           String           @id @default(uuid()) @db.Uuid
  masjid       Masjid           @relation(fields: [masjidId], references: [id], onDelete: Cascade)
  masjidId     String           @map("masjid_id") @db.Uuid
  type         RelationshipType
  /// For PARENT this is the parent; for SPOUSE this is the lower-sorted member id.
  fromMember   HouseholdMember  @relation("RelFrom", fields: [fromMemberId], references: [id], onDelete: Cascade)
  fromMemberId String           @map("from_member_id") @db.Uuid
  /// For PARENT this is the child; for SPOUSE this is the higher-sorted member id.
  toMember     HouseholdMember  @relation("RelTo", fields: [toMemberId], references: [id], onDelete: Cascade)
  toMemberId   String           @map("to_member_id") @db.Uuid
  createdAt    DateTime         @default(now()) @map("created_at")

  @@unique([fromMemberId, toMemberId, type])
  @@index([masjidId])
  @@index([fromMemberId])
  @@index([toMemberId])
  @@map("member_relationships")
}

model PrayerTimetableEntry {
  id            String   @id @default(uuid()) @db.Uuid
  masjid        Masjid   @relation(fields: [masjidId], references: [id], onDelete: Cascade)
  masjidId      String   @map("masjid_id") @db.Uuid
  /// Calendar date in the masjid's local timezone.
  date          DateTime @db.Date
  /// All times are local wall-clock "HH:MM" strings in the masjid's timezone.
  fajr          String
  fajrIqamah    String?  @map("fajr_iqamah")
  dhuhr         String
  dhuhrIqamah   String?  @map("dhuhr_iqamah")
  asr           String
  asrIqamah     String?  @map("asr_iqamah")
  maghrib       String
  maghribIqamah String?  @map("maghrib_iqamah")
  isha          String
  ishaIqamah    String?  @map("isha_iqamah")
  jumuah1       String?
  jumuah2       String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([masjidId, date])
  @@map("prayer_timetable_entries")
}

model Announcement {
  id          String        @id @default(uuid()) @db.Uuid
  masjid      Masjid        @relation(fields: [masjidId], references: [id], onDelete: Cascade)
  masjidId    String        @map("masjid_id") @db.Uuid
  title       String
  body        String
  status      ContentStatus @default(DRAFT)
  publishedAt DateTime?     @map("published_at")
  createdBy   User?         @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdById String?       @map("created_by_id") @db.Uuid
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([masjidId, status])
  @@map("announcements")
}

model Event {
  id          String      @id @default(uuid()) @db.Uuid
  masjid      Masjid      @relation(fields: [masjidId], references: [id], onDelete: Cascade)
  masjidId    String      @map("masjid_id") @db.Uuid
  title       String
  description String?
  location    String?
  startsAt    DateTime    @map("starts_at")
  endsAt      DateTime?   @map("ends_at")
  status      EventStatus @default(DRAFT)
  createdBy   User?       @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdById String?     @map("created_by_id") @db.Uuid
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@index([masjidId, startsAt])
  @@index([masjidId, status])
  @@map("events")
}

model Invitation {
  id          String    @id @default(uuid()) @db.Uuid
  email       String
  firstName   String    @map("first_name")
  lastName    String    @map("last_name")
  role        UserRole
  masjid      Masjid    @relation(fields: [masjidId], references: [id], onDelete: Cascade)
  masjidId    String    @map("masjid_id") @db.Uuid
  invitedBy   User?     @relation("InvitationsSent", fields: [invitedById], references: [id], onDelete: SetNull)
  invitedById String?   @map("invited_by_id") @db.Uuid
  tokenHash   String    @unique @map("token_hash")
  expiresAt   DateTime  @map("expires_at")
  acceptedAt  DateTime? @map("accepted_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([masjidId])
  @@index([email])
  @@map("invitations")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  action     String
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorId    String?  @map("actor_id") @db.Uuid
  /// Snapshot of the actor's email at the time of the action.
  actorEmail String?  @map("actor_email")
  masjidId   String?  @map("masjid_id") @db.Uuid
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([masjidId, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  tokenHash String    @unique @map("token_hash")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String    @map("user_id") @db.Uuid
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  tokenHash String    @unique @map("token_hash")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String    @map("user_id") @db.Uuid
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}
